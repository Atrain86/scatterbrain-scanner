## DATA MODEL

All data lives in IndexedDB locally and syncs to cloud storage as JSON + image pairs.

### Receipt Record
```typescript
interface Receipt {
  id: string;                    // UUID generated client-side
  imageBlob: Blob;               // Original photo (stored in IndexedDB)
  imageThumbnail: Blob;          // Compressed thumbnail for list view
  
  // OCR-extracted fields (editable by user)
  storeName: string;
  date: string;                  // ISO date
  items: ReceiptItem[];
  subtotal: number;
  tax: number;
  total: number;
  currency: string;              // default CAD
  category: ReceiptCategory;
  notes: string;
  
  // Sync metadata
  cloudFileId: string | null;    // Drive file ID or Dropbox path
  cloudMetaId: string | null;    // JSON companion file ID
  syncStatus: 'pending' | 'synced' | 'failed' | 'offline-queued';
  lastSynced: string | null;     // ISO timestamp
  
  // Local metadata
  createdAt: string;
  updatedAt: string;
}

interface ReceiptItem {
  description: string;
  quantity: number;
  price: number;
}

type ReceiptCategory = 
  | 'materials'      // Paint, lumber, supplies
  | 'tools'          // Equipment purchases
  | 'fuel'           // Gas, ferry, travel
  | 'food'           // Meals on the job
  | 'vehicle'        // Maintenance, parts
  | 'office'         // Admin supplies
  | 'subcontractor'  // Hired help
  | 'other';
```

### App Settings (synced to cloud)
```typescript
interface AppSettings {
  cloudProvider: 'google-drive' | 'dropbox' | null;
  cloudConnected: boolean;
  cloudEmail: string | null;
  defaultCategory: ReceiptCategory;
  currency: string;
  autoSync: boolean;             // Upload immediately after scan
  darkMode: boolean;
  hapticFeedback: boolean;
}
