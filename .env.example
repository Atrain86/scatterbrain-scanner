# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ─── Resend (email) ────────────────────────────────────────────────────────────
RESEND_API_KEY=

# ─── Cloudflare R2 (receipt image storage) ────────────────────────────────────
# Create a NEW R2 bucket — do NOT reuse PaintBrain's bucket
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=scatterbrain-receipts
R2_PUBLIC_URL=

# ─── Google Drive OAuth ────────────────────────────────────────────────────────
# Create a NEW Google OAuth app in Google Cloud Console
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3002/api/auth/google/callback

# ─── Dropbox OAuth ────────────────────────────────────────────────────────────
# Create a NEW Dropbox app (App folder access)
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=
DROPBOX_REDIRECT_URI=http://localhost:3002/api/auth/dropbox/callback

# ─── PostHog Analytics ────────────────────────────────────────────────────────
# Create a NEW PostHog project — do NOT reuse PaintBrain's token
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://app.posthog.com

# ─── Database ─────────────────────────────────────────────────────────────────
# Local dev: SQLite (leave as default below)
# Production: Render PostgreSQL connection string
DATABASE_URL=./data/scatterbrain.db

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3002
NODE_ENV=development
